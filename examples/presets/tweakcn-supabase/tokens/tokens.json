{
  "color": {
    "$type": "color",
    "background":         { "$value": "oklch(100% 0 0)" },
    "foreground":         { "$value": "oklch(15% 0.01 160)" },
    "card":               { "$value": "oklch(99% 0.005 160)" },
    "card-foreground":    { "$value": "oklch(15% 0.01 160)" },
    "primary":            { "$value": "oklch(72% 0.17 145)" },
    "primary-foreground": { "$value": "oklch(12% 0.02 160)" },
    "muted":              { "$value": "oklch(95% 0.005 160)" },
    "muted-foreground":   { "$value": "oklch(45% 0.01 160)" },
    "accent":             { "$value": "oklch(72% 0.17 145)" },
    "accent-foreground":  { "$value": "oklch(12% 0.02 160)" },
    "border":             { "$value": "oklch(90% 0.005 160)" },
    "input":              { "$value": "oklch(92% 0.005 160)" },
    "ring":               { "$value": "oklch(72% 0.17 145)" }
  },
  "color-dark": {
    "$type": "color",
    "background":         { "$value": "oklch(12% 0.02 160)" },
    "foreground":         { "$value": "oklch(96% 0.005 160)" },
    "card":               { "$value": "oklch(16% 0.02 160)" },
    "card-foreground":    { "$value": "oklch(96% 0.005 160)" },
    "primary":            { "$value": "oklch(72% 0.17 145)" },
    "primary-foreground": { "$value": "oklch(12% 0.02 160)" },
    "muted":              { "$value": "oklch(20% 0.015 160)" },
    "muted-foreground":   { "$value": "oklch(68% 0.01 160)" },
    "accent":             { "$value": "oklch(72% 0.17 145)" },
    "accent-foreground":  { "$value": "oklch(12% 0.02 160)" },
    "border":             { "$value": "oklch(24% 0.015 160)" },
    "input":              { "$value": "oklch(24% 0.015 160)" },
    "ring":               { "$value": "oklch(72% 0.17 145)" }
  },
  "spacing": {
    "$type": "dimension",
    "xs": { "$value": "4px" },
    "sm": { "$value": "8px" },
    "md": { "$value": "16px" },
    "lg": { "$value": "24px" },
    "xl": { "$value": "32px" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "4px" },
    "md": { "$value": "6px" },
    "lg": { "$value": "8px" }
  },
  "shadow": {
    "$type": "shadow",
    "sm": { "$value": "0 1px 2px 0 rgb(0 0 0 / 0.3)" },
    "md": { "$value": "0 6px 20px -4px rgb(0 0 0 / 0.4)" }
  }
}
