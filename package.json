{
  "name": "@sarveshsea/memoire",
  "version": "0.2.1",
  "description": "AI-Native Design Intelligence Engine — Figma + Research + Spec-Driven Code Generation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "memoire": "./dist/index.js",
    "memi": "./dist/index.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:changelog": "node scripts/build-changelog-preview.mjs",
    "build:plugin": "node scripts/build-plugin.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "preview": "vite --config preview/vite.config.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit && tsc -p tsconfig.plugin.json --noEmit",
    "typecheck": "tsc --noEmit --strict && tsc -p tsconfig.plugin.json --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "prepare": "npm run build",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sarveshsea/m-moire.git"
  },
  "author": "Sarvesh Chidambaram",
  "license": "MIT",
  "keywords": [
    "design-system",
    "figma",
    "ai",
    "code-generation",
    "shadcn",
    "atomic-design",
    "claude",
    "design-intelligence"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "scripts/postinstall.mjs",
    "skills",
    "notes",
    "plugin",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bugs": {
    "url": "https://github.com/sarveshsea/m-moire/issues"
  },
  "homepage": "https://memoire.cv",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "commander": "^12.1.0",
    "exceljs": "^4.4.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "react": "^18.3.1",
    "ws": "^8.18.0",
    "zod": "^3.25.0",
    "chalk": "^5.4.0",
    "boxen": "^8.0.1",
    "ora": "^8.1.0",
    "figures": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
